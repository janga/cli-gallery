---
import { getCollection } from 'astro:content';
import SiteNavigation from '../components/SiteNavigation.astro';
import SiteSection from '../components/SiteSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSectionsContent } from '../lib/sectionContent';

const siteDirectory = (process.env.CLI_GALLERY_SITE_DIR ?? 'site').trim();
const siteContentLabel = `${siteDirectory || 'site'}/content.md`;
const [site] = await getCollection('site');

if (!site) {
	throw new Error(`Content file ${siteContentLabel} is missing.`);
}

const sections = site.data.sections;
const siteHtml = site.rendered?.html ?? '';
const resolvedSections = getSectionsContent(siteHtml, sections);
---

<BaseLayout title={site.data.title} description={site.data.description}>
	<SiteNavigation sections={resolvedSections} />

	<main id="main-content" class="site-content">
		{resolvedSections.map((section, index) => (
			<SiteSection
				section={section}
				headingLevel={index === 0 ? 1 : 2}
				priorityGalleryImage={index === 0}
			/>
		))}
	</main>
</BaseLayout>

---
import type { CollectionEntry } from 'astro:content';
import projectConfig from '../../scripts/lib/project-config.mjs';

type SiteSection = CollectionEntry<'site'>['data']['sections'][number];
type SiteDefaultPresentation = CollectionEntry<'site'>['data']['defaultPresentation'];
type ResolvedSection = SiteSection & { title: string };

interface Props {
	sections: ResolvedSection[];
	defaultPresentation?: SiteDefaultPresentation;
}

const { sections, defaultPresentation: configuredDefaultPresentation } = Astro.props;
const smoothScrollConfig = projectConfig.navigation.smoothScroll;
const fallbackNavigationBackgroundColor = 'var(--color-nav-background)';
const fallbackNavigationTextColor = 'var(--color-text)';
const navigationStyle = [
	`--site-top-background-color: ${configuredDefaultPresentation?.backgroundColor ?? fallbackNavigationBackgroundColor}`,
	`--site-top-text-color: ${configuredDefaultPresentation?.textColor ?? fallbackNavigationTextColor}`,
].join('; ');
---

<a class="skip-link" href="#main-content">Hoppa till innehåll</a>

<header class="site-top" data-smooth-scroll={JSON.stringify(smoothScrollConfig)} style={navigationStyle}>
	<nav class="section-nav" aria-label="Sektioner">
		<ul>
			{sections.map((section, index) => (
				<li>
					<a href={`#${section.id}`} aria-current={index === 0 ? 'true' : undefined}>
						{section.title}
					</a>
				</li>
			))}
		</ul>
	</nav>
</header>

<script>
	const siteTop = document.querySelector('.site-top');
	const sections = Array.from(document.querySelectorAll('.site-section'));
	const links = Array.from(document.querySelectorAll('.section-nav a'));
	const smoothScrollConfig = JSON.parse(siteTop?.getAttribute('data-smooth-scroll') ?? '{}');
	const anchorPadding = 14;
	const maximumAnchorGap = 80;
	const anchorCorrectionDelays = [120, 320, 700, 1_000, 2_000];
	const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
	const minimumScrollDuration = smoothScrollConfig.minimumDurationMs;
	const maximumScrollDuration = smoothScrollConfig.maximumDurationMs;
	const scrollDurationPerPixel = smoothScrollConfig.durationPerPixelMs;
	const scrollInterruptEvents = ['wheel', 'touchstart'];
	const scrollInterruptKeys = new Set(['ArrowDown', 'ArrowUp', 'End', 'Home', 'PageDown', 'PageUp', ' ']);
	let activeScrollAnimation = null;
	let recentAnchorSection = null;
	let correctAnchorUntil = 0;
	let missedAnchorCorrectionStartsAt = 0;

	const setAnchorOffset = () => {
		if (!(siteTop instanceof HTMLElement)) return;

		const offset = Math.ceil(siteTop.getBoundingClientRect().height + anchorPadding);
		document.documentElement.style.setProperty('--site-top-anchor-offset', `${offset}px`);
		return offset;
	};

	const getSectionFromHash = (hash) => {
		const id = hash.replace(/^#/, '');
		return sections.find((section) => section.id === id);
	};

	const clearRecentAnchor = () => {
		recentAnchorSection = null;
		correctAnchorUntil = 0;
		missedAnchorCorrectionStartsAt = 0;
	};

	const cancelActiveScroll = ({ clearAnchor = false } = {}) => {
		if (activeScrollAnimation) {
			activeScrollAnimation.cancel();
			activeScrollAnimation = null;
		}

		if (clearAnchor) {
			clearRecentAnchor();
		}
	};

	const setActiveSection = (section) => {
		if (!section) return;

		links.forEach((link) => {
			const isActive = link.getAttribute('href') === `#${section.id}`;
			if (isActive) {
				link.setAttribute('aria-current', 'true');
			} else {
				link.removeAttribute('aria-current');
			}
		});
	};

	const setHash = (targetHash) => {
		if (window.location.hash !== targetHash) {
			history.pushState(null, '', targetHash);
		}
	};

	const getSectionScrollTop = (section) => {
		if (!(section instanceof HTMLElement)) return;

		const offset = setAnchorOffset();
		if (!offset) return;

		return Math.max(0, section.getBoundingClientRect().top + window.scrollY - offset);
	};

	const jumpTo = (top) => {
		cancelActiveScroll();

		const root = document.documentElement;
		const previousScrollBehavior = root.style.scrollBehavior;
		root.style.scrollBehavior = 'auto';
		window.scrollTo(0, top);
		root.style.scrollBehavior = previousScrollBehavior;
	};

	const getScrollDuration = (distance) => {
		const distancePx = Math.abs(distance);

		if (!smoothScrollConfig.enabled || reduceMotionQuery.matches || distancePx < anchorPadding) return 0;

		return Math.min(
			maximumScrollDuration,
			Math.max(minimumScrollDuration, distancePx * scrollDurationPerPixel),
		);
	};

	const easeInOutCubic = (progress) => (
		progress < 0.5
			? 4 * progress * progress * progress
			: 1 - Math.pow(-2 * progress + 2, 3) / 2
	);

	const animateScrollTo = (
		target,
		{ duration, onComplete } = {},
	) => {
		cancelActiveScroll();

		const getTop = typeof target === 'function' ? target : () => target;
		let latestTop = getTop();
		if (latestTop === undefined) return 0;

		const startY = window.scrollY;
		const distance = latestTop - startY;
		const scrollDuration = duration ?? getScrollDuration(distance);

		if (scrollDuration <= 0) {
			const top = getTop();
			if (top === undefined) return 0;

			jumpTo(top);
			onComplete?.();
			return 0;
		}

		const root = document.documentElement;
		const previousScrollBehavior = root.style.scrollBehavior;
		const startedAt = performance.now();
		let frameId = 0;

		const state = {
			cancel: () => {},
		};

		const cleanup = () => {
			scrollInterruptEvents.forEach((eventName) => {
				window.removeEventListener(eventName, interruptScroll);
			});
			window.removeEventListener('keydown', interruptScrollKey);
			root.style.scrollBehavior = previousScrollBehavior;

			if (activeScrollAnimation === state) {
				activeScrollAnimation = null;
			}
		};

		const cancel = ({ clearAnchor = true } = {}) => {
			if (frameId) {
				cancelAnimationFrame(frameId);
			}

			cleanup();

			if (clearAnchor) {
				clearRecentAnchor();
			}
		};

		const interruptScroll = () => cancel({ clearAnchor: true });
		const interruptScrollKey = (event) => {
			if (scrollInterruptKeys.has(event.key)) {
				interruptScroll();
			}
		};

		const step = (now) => {
			const elapsed = now - startedAt;
			const progress = Math.min(1, elapsed / scrollDuration);
			const top = getTop();
			if (top !== undefined) {
				latestTop = top;
			}

			const nextY = startY + (latestTop - startY) * easeInOutCubic(progress);

			window.scrollTo(0, nextY);

			if (progress >= 1) {
				window.scrollTo(0, latestTop);
				cleanup();
				onComplete?.();
				requestAnimationFrame(correctRecentAnchor);
				return;
			}

			frameId = requestAnimationFrame(step);
		};

		state.cancel = cancel;
		activeScrollAnimation = state;
		root.style.scrollBehavior = 'auto';
		scrollInterruptEvents.forEach((eventName) => {
			window.addEventListener(eventName, interruptScroll, { passive: true });
		});
		window.addEventListener('keydown', interruptScrollKey);
		frameId = requestAnimationFrame(step);

		return scrollDuration;
	};

	const scrollToSection = (section, { behavior = 'smooth', duration, onComplete } = {}) => {
		const top = getSectionScrollTop(section);
		if (top === undefined) return 0;

		const scrollDuration = behavior === 'smooth'
			? animateScrollTo(() => getSectionScrollTop(section), { duration, onComplete })
			: (jumpTo(top), onComplete?.(), 0);

		setActiveSection(section);

		return scrollDuration;
	};

	const trackRecentAnchor = (section, { missedAnchorDelay = 1_200 } = {}) => {
		const now = performance.now();

		recentAnchorSection = section;
		correctAnchorUntil = now + Math.max(2_700, missedAnchorDelay + 1_500);
		missedAnchorCorrectionStartsAt = now + missedAnchorDelay;

		const correctionDelays = [...new Set([
			...anchorCorrectionDelays,
			missedAnchorDelay,
			missedAnchorDelay + 500,
			missedAnchorDelay + 1_200,
		])].sort((a, b) => a - b);

		correctionDelays.forEach((delay) => {
			window.setTimeout(() => requestAnimationFrame(correctRecentAnchor), delay);
		});
	};

	const correctRecentAnchor = () => {
		if (activeScrollAnimation) return;
		if (!(recentAnchorSection instanceof HTMLElement)) return;
		if (performance.now() > correctAnchorUntil) return;
		if (window.location.hash !== `#${recentAnchorSection.id}`) return;

		const heading = recentAnchorSection.querySelector('h1, h2');
		if (!(siteTop instanceof HTMLElement) || !(heading instanceof HTMLElement)) return;

		const headerBottom = siteTop.getBoundingClientRect().bottom;
		const headingTop = heading.getBoundingClientRect().top;
		const hiddenBehindHeader = headingTop < headerBottom - 1;
		const canCorrectMissedAnchor = performance.now() >= missedAnchorCorrectionStartsAt;
		const missedAnchorScroll = canCorrectMissedAnchor && headingTop > headerBottom + maximumAnchorGap;

		if (hiddenBehindHeader || missedAnchorScroll) {
			scrollToSection(recentAnchorSection, { behavior: 'auto' });
		}
	};

	const updateAnchorOffset = () => {
		setAnchorOffset();
		requestAnimationFrame(correctRecentAnchor);
	};

	const observer = new IntersectionObserver(
		(entries) => {
			const visible = entries
				.filter((entry) => entry.isIntersecting)
				.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

			if (visible?.target) {
				setActiveSection(visible.target);
			}
		},
		{
			rootMargin: '-35% 0px -55% 0px',
			threshold: [0, 0.25, 0.5, 0.75, 1],
		},
	);

	sections.forEach((section) => observer.observe(section));

	links.forEach((link) => {
		link.addEventListener('click', (event) => {
			const section = getSectionFromHash(link.hash);
			if (!(section instanceof HTMLElement)) return;

			const top = getSectionScrollTop(section);
			if (top === undefined) return;

			event.preventDefault();

			const targetHash = `#${section.id}`;
			const duration = getScrollDuration(top - window.scrollY);

			trackRecentAnchor(section, { missedAnchorDelay: duration + 350 });
			setActiveSection(section);

			scrollToSection(section, {
				behavior: 'smooth',
				duration,
				onComplete: () => setHash(targetHash),
			});
		});
	});

	const trackCurrentHashAnchor = ({ scrollImmediately = false } = {}) => {
		const section = getSectionFromHash(window.location.hash);
		if (!(section instanceof HTMLElement)) return;

		trackRecentAnchor(section, { missedAnchorDelay: scrollImmediately ? 0 : 1_200 });

		if (scrollImmediately) {
			requestAnimationFrame(() => scrollToSection(section, { behavior: 'auto' }));
			return;
		}

		requestAnimationFrame(correctRecentAnchor);
	};

	const initialSection = getSectionFromHash(window.location.hash);
	if (initialSection instanceof HTMLElement) {
		trackCurrentHashAnchor({ scrollImmediately: true });
	}

	updateAnchorOffset();

	if (siteTop instanceof HTMLElement && 'ResizeObserver' in window) {
		new ResizeObserver(updateAnchorOffset).observe(siteTop);
	}

	window.addEventListener('resize', updateAnchorOffset);
	window.addEventListener('hashchange', () => trackCurrentHashAnchor());
	window.addEventListener('popstate', () => trackCurrentHashAnchor());
	window.addEventListener('scrollend', () => requestAnimationFrame(correctRecentAnchor));

	if (window.visualViewport) {
		window.visualViewport.addEventListener('resize', updateAnchorOffset);
	}
</script>

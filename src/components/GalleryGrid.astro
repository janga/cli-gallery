---
import type { CollectionEntry } from 'astro:content';
import { getGeneratedImage, getImageAttributes, getLinkedImageSrc } from '../lib/generatedImages';

type SiteSection = CollectionEntry<'site'>['data']['sections'][number];
type GalleryImage = SiteSection['gallery'][number];

interface Props {
	title: string;
	images: GalleryImage[];
	priorityFirstImage?: boolean;
}

const { title, images, priorityFirstImage = false } = Astro.props;
const galleryImageSizes = '(max-width: 700px) calc(100vw - 2rem), 880px';
---

<div class="gallery" aria-label={`Galleri: ${title}`}>
	{images.map((image, index) => {
		const isPriority = priorityFirstImage && index === 0;
		const generatedImage = getGeneratedImage(image.image);
		const imageClass = generatedImage && generatedImage.width > generatedImage.height
			? 'gallery-image-landscape'
			: undefined;

		return (
		<article class="gallery-item">
			<a
				href={getLinkedImageSrc(image.image)}
				class="gallery-image-link"
			>
				<img
					{...getImageAttributes(image.image, galleryImageSizes)}
					class:list={[imageClass]}
					alt={image.alt}
					decoding="async"
					fetchpriority={isPriority ? 'high' : 'low'}
					loading={isPriority ? 'eager' : 'lazy'}
				/>
			</a>
			{image.caption && (
				<div class="gallery-meta">
					<div class="gallery-details">
						<span>{image.caption}</span>
					</div>
				</div>
			)}
		</article>
		);
	})}
</div>

---
import type { CollectionEntry } from 'astro:content';
import projectConfig from '../../scripts/lib/project-config.mjs';
import '../styles/global.css';

type SiteDefaultPresentation = CollectionEntry<'site'>['data']['defaultPresentation'];

interface Props {
	title?: string;
	description?: string;
	defaultPresentation?: SiteDefaultPresentation;
}

const {
	title = 'cli-gallery',
	description = 'A cli-gallery site.',
	defaultPresentation: configuredDefaultPresentation,
} = Astro.props;

const documentTitle = title;
const canonicalUrl = projectConfig.site.url;
const scrollBehavior = projectConfig.navigation.smoothScroll.enabled ? 'smooth' : 'auto';
const documentStyle = [
	`scroll-behavior: ${scrollBehavior}`,
	`--font-sans: ${projectConfig.typography.fontFamily}`,
].join('; ');
const { buildInfo, copyrightMessage } = projectConfig.footer;
const showBuildInfo = Boolean(buildInfo?.enabled);
const buildTime = showBuildInfo
	? new Intl.DateTimeFormat(buildInfo.dateTimeFormat.locale, {
		dateStyle: buildInfo.dateTimeFormat.dateStyle,
		timeStyle: buildInfo.dateTimeFormat.timeStyle,
		timeZone: buildInfo.dateTimeFormat.timeZone,
	}).format(new Date())
	: null;
const showFooter = Boolean(copyrightMessage || showBuildInfo);
const footerStyle = [
	`--site-footer-background-color: ${configuredDefaultPresentation?.backgroundColor ?? 'var(--color-page)'}`,
	`--site-footer-text-color: ${configuredDefaultPresentation?.textColor ?? 'var(--color-muted)'}`,
].join('; ');
---

<!doctype html>
<html lang="sv" style={documentStyle}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#000000" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{documentTitle}</title>
	</head>
	<body>
		<slot />
		{showFooter && (
			<footer class="site-footer" style={footerStyle}>
				<p>
					{copyrightMessage}
					{showBuildInfo && <span>{buildInfo.text} {buildTime}</span>}
				</p>
			</footer>
		)}
	</body>
</html>

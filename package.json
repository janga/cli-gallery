{
  "name": "@janga/cli-gallery",
  "description": "A command-line publishing workflow for simple static galleries.",
  "type": "module",
  "version": "0.1.15",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janga/cli-gallery.git"
  },
  "bugs": {
    "url": "https://github.com/janga/cli-gallery/issues"
  },
  "homepage": "https://github.com/janga/cli-gallery#readme",
  "keywords": [
    "astro",
    "gallery",
    "static-site",
    "cli"
  ],
  "bin": {
    "cli-gallery": "bin/cli-gallery.mjs"
  },
  "files": [
    "astro.config.mjs",
    "bin/",
    "docs/",
    "fixtures/",
    "scripts/",
    "src/",
    "starters/",
    "!**/.cli-gallery/public/",
    "tsconfig.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "npm run demo:dev",
    "dev:restart": "node bin/cli-gallery.mjs dev:restart",
    "dev:status": "node bin/cli-gallery.mjs dev:status",
    "dev:logs": "node bin/cli-gallery.mjs dev:logs",
    "dev:stop": "node bin/cli-gallery.mjs dev:stop",
    "config:check": "node bin/cli-gallery.mjs config:check",
    "content:check": "node bin/cli-gallery.mjs content:check",
    "content:sync": "node bin/cli-gallery.mjs content:sync",
    "site:public": "node bin/cli-gallery.mjs site:public",
    "images": "node bin/cli-gallery.mjs images",
    "build": "npm run demo:build",
    "build:local": "node bin/cli-gallery.mjs build:local",
    "deploy": "node bin/cli-gallery.mjs deploy",
    "deploy:commit": "node bin/cli-gallery.mjs deploy:commit",
    "deploy:watch": "node bin/cli-gallery.mjs deploy:watch",
    "doctor": "node bin/cli-gallery.mjs doctor",
    "demo:dev": "node bin/cli-gallery.mjs dev:local",
    "demo:build": "node bin/cli-gallery.mjs build",
    "test": "npm run test:content-check && npm run test:site-public && npm run test:fixture:build && npm run demo:build && npm run package:check",
    "test:fixture:build": "node bin/cli-gallery.mjs --site-dir fixtures/basic/site build",
    "test:content-check": "node scripts/test-content-check.mjs",
    "test:site-public": "node scripts/test-site-public.mjs",
    "test:navigation": "node scripts/test-navigation.mjs",
    "test:navigation:stress": "node scripts/test-navigation.mjs tests/navigation-stress.spec.ts",
    "test:navigation:preview": "node scripts/test-navigation-preview.mjs",
    "package:check": "node scripts/test-package-check.mjs",
    "release:publish": "npm publish --access public --registry=https://registry.npmjs.org/ --cache /private/tmp/cli-gallery-npm-cache",
    "preview": "node bin/cli-gallery.mjs preview",
    "astro": "node bin/cli-gallery.mjs astro"
  },
  "dependencies": {
    "astro": "^7.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
